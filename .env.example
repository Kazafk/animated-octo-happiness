# Obsidian Local REST API Configuration
# Get these values from your Obsidian vault settings

# Your Obsidian API endpoint (typically runs on localhost:27124)
OBSIDIAN_API_URL=https://127.0.0.1:27124

# Your authentication token from Obsidian Local REST API plugin
OBSIDIAN_AUTH_TOKEN=your_token_here

# Comma-separated list of projects to export
# (optional, defaults to the list in the script)
PROJECTS_LIST=Project 1,Project 2,Project 3

# Enable automatic git commit and push when running the export script
GIT_AUTO_COMMIT=false
